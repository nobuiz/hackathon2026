# Copy to .env and fill in. EVERY key is optional — leave blank to run in mock mode.
# The app works fully without any of these; add a key to switch that engine to "live".

# Anthropic — extraction + denial-risk reasoning (core reasoning)
ANTHROPIC_API_KEY=

# Redis — inter-agent session state (e.g. redis://localhost:6379/0)
REDIS_URL=

# Sentry — captures pipeline exceptions  (Best Use of Sentry API)
SENTRY_DSN=

# Deepgram — transcribes phone/voice referrals before they hit the pipeline
DEEPGRAM_API_KEY=

# Browserbase — hosted headless browser that submits PAs to payer portals
BROWSERBASE_API_KEY= bb_live_uZvouQdldClvWAwAXy2vQv07RnA
BROWSERBASE_PROJECT_ID= b39221e8-60cf-4dcd-8f1d-c4d8307dc51b
PAYER_PORTAL_URL= https://forms.gle/466ERgZVkpFCfGBP6

# Arize Phoenix — agent decision-trace tracing (run `phoenix serve`, default below)
# Without this, spans are still written to backend/traces.jsonl
PHOENIX_COLLECTOR_ENDPOINT=

# Orkes Conductor — durable orchestration + the human-approval gate
CONDUCTOR_SERVER_URL=
CONDUCTOR_AUTH_KEY=
CONDUCTOR_AUTH_SECRET=

# Fetch.ai / ASI:One — the ASI:One-discoverable agent (run backend/fetch_agent.py)
FETCH_AGENT_SEED=referralguard-demo-seed
CLINIC_AGENT_SEED=clinic-demo-seed
AGENTVERSE_API_KEY=
ASI_ONE_API_KEY=
